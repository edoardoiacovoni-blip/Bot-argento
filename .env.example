# Pionex API Credentials (obbligatorie)
PIONEX_API_KEY=your_pionex_api_key_here
PIONEX_SECRET_KEY=your_pionex_secret_key_here

# Modalità trading: 0 = ordini reali, 1 = simulazione (default consigliato per test)
DRY_RUN=1

# Simbolo e timeframe
SYMBOL=XAG_USDT
TIMEFRAME=5m

# Parametri loop worker
LOOP_SECONDS=10

# Gestione rischio
MICRO_TRADE_USDT=5
MAX_TRADES_PER_HOUR=20
MAX_DAILY_DRAWDOWN=0.02
MAX_SPREAD_BPS=10
MAX_CONSECUTIVE_LOSSES=5

# Sessione di trading (ore UTC)
SESSION_START_UTC=9
SESSION_END_UTC=22

# Indicatori tecnici
RSI_OVERSOLD=30

# Provider esterni (DXY e Notizie)
# STRICT_EXTERNALS=0 => se il provider manca, il check viene saltato (non blocca)
# STRICT_EXTERNALS=1 => se il provider manca, il check fallisce e blocca il trading
STRICT_EXTERNALS=0

# DXY Provider: "none" (disabilitato) o "url" (custom endpoint)
DXY_PROVIDER=none
# DXY_URL=https://your-dxy-api.example.com/bias
# DXY_API_KEY=your_dxy_api_key_here

# News Provider: "none" (disabilitato) o "url" (custom endpoint)
NEWS_PROVIDER=none
# NEWS_URL=https://your-news-api.example.com/high-impact
# NEWS_API_KEY=your_news_api_key_here
