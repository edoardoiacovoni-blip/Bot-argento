# Pionex API Credentials
PIONEX_API_KEY=your_pionex_api_key_here
PIONEX_SECRET_KEY=your_pionex_secret_key_here

# Modalità DRY_RUN: 1 = nessun ordine reale (default consigliato), 0 = trading reale
DRY_RUN=1

# Simbolo argento SPOT su Pionex (obbligatorio, es. XAG_USDT)
SILVER_SYMBOL=XAG_USDT

# Importo in USDT da spendere per ogni acquisto di argento (default: 5)
SILVER_BUY_AMOUNT_USDT=5

# Capitale totale gestito in USDT (Punto 6 & 8 — default: 67.0)
TOTAL_CAPITAL=67.0

# Soglia minima USDT per eseguire un salto; se inferiore si attiva il rebalancing (default: 5.0)
TRADE_MARGIN=5.0

# Soglia minima valore XAG (in USDT) sotto la quale non si vende argento (default: 10.0)
MIN_USDT_RESERVE=10.0

# 1 = accumula argento ogni ciclo (default: 1), 0 = disabilita accumulo automatico
ENABLE_SILVER_ACCUMULATION=1

# Target volatili per i "salti": simboli separati da virgola (default: BTC_USDT,ETH_USDT,SOL_USDT)
VOLATILE_TARGETS=BTC_USDT,ETH_USDT,SOL_USDT

# Quantità base da acquistare per ogni micro-trade (default: 0.01 unità)
MICRO_TRADE_QUANTITY=0.01

# Render Environment (automatically set by Render)
# RENDER=true
