# Pionex API Credentials
PIONEX_API_KEY=your_pionex_api_key_here
PIONEX_SECRET_KEY=your_pionex_secret_key_here

# Modalità DRY_RUN: 1 = nessun ordine reale (default consigliato), 0 = trading reale
DRY_RUN=1

# Simbolo argento SPOT su Pionex (obbligatorio, es. XAG_USDT)
SILVER_SYMBOL=XAG_USDT

# Importo in USDT da spendere per ogni acquisto di argento (default: 5)
SILVER_BUY_AMOUNT_USDT=5

# Render Environment (automatically set by Render)
# RENDER=true
