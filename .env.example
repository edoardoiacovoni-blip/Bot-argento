# Pionex API Credentials
PIONEX_API_KEY=your_pionex_api_key_here
PIONEX_SECRET_KEY=your_pionex_secret_key_here

# Modalità DRY_RUN: 1 = nessun ordine reale (default consigliato), 0 = trading reale
DRY_RUN=1

# Simbolo argento SPOT su Pionex (obbligatorio, es. XAG_USDT)
SILVER_SYMBOL=XAG_USDT

# Importo in USDT da spendere per ogni acquisto di argento (default: 5)
SILVER_BUY_AMOUNT_USDT=5

# Abilita l'accumulo automatico di argento: 1 = attivo, 0 = disabilitato (default: 0)
ENABLE_SILVER_ACCUMULATION=0

# Gestione liquidità USDT/XAG
# Soglia USDT libero sotto la quale scatta la vendita di XAG (default: 10.0)
MIN_USDT_RESERVE=10.0
# Obiettivo USDT dopo il rebalancing (default: uguale a MIN_USDT_RESERVE)
TARGET_USDT_AFTER_REBALANCE=10.0
# Cooldown in secondi tra vendite successive di XAG (default: 300 = 5 minuti)
REBALANCE_COOLDOWN_SEC=300
# Notional minimo in USDT per eseguire una vendita XAG (evita micro-ordini, default: 2.0)
MIN_XAG_NOTIONAL_TO_SELL=2.0

# Render Environment (automatically set by Render)
# RENDER=true
