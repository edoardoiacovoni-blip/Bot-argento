# Pionex API Credentials
PIONEX_API_KEY=your_pionex_api_key_here
PIONEX_SECRET_KEY=your_pionex_secret_key_here

# Modalità DRY_RUN: 1 = nessun ordine reale (default consigliato), 0 = trading reale
DRY_RUN=1

# Simbolo argento SPOT su Pionex (obbligatorio, es. XAG_USDT)
SILVER_SYMBOL=XAG_USDT

# Importo in USDT da spendere per ogni acquisto di argento (default: 5)
SILVER_BUY_AMOUNT_USDT=5

# Capitale totale di riferimento in USDT (default: 67.0)
TOTAL_CAPITAL=67.0

# Margine USDT minimo per eseguire un micro-trade (default: 5.0)
TRADE_MARGIN=5.0

# Asset volatili da monitorare per opportunità di salto (separati da virgola)
VOLATILE_TARGETS=BTC_USDT,ETH_USDT,SOL_USDT

# Abilita l'accumulo automatico di argento dai profitti: 1 = abilitato (default), 0 = disabilitato
ENABLE_SILVER_ACCUMULATION=1

# Render Environment (automatically set by Render)
# RENDER=true
